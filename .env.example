# ============================================================================
# بكالوريا بيه - Environment Variables (EXAMPLE)
# Copy this file to .env and fill in your real values
# ============================================================================

# ---- App ----
NODE_ENV=development
NEXT_PUBLIC_APP_NAME="بكالوريا بيه"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---- Database (Supabase PostgreSQL) ----
# Use the connection POOLER for app runtime (IPv4, port 6543)
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL="postgresql://postgres.towfnhenuhjflkkgbagi:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres"

# Use the DIRECT connection for migrations (IPv4, port 5432)
DIRECT_URL="postgresql://postgres.towfnhenuhjflkkgbagi:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# ---- Supabase Auth ----
NEXT_PUBLIC_SUPABASE_URL="https://towfnhenuhjflkkgbagi.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxx"
SUPABASE_SERVICE_ROLE_KEY="sb_secret_xxx"

# ---- NextAuth ----
NEXTAUTH_SECRET="generate-a-random-32-char-string-here"
NEXTAUTH_URL="http://localhost:3000"

# ---- Cloudflare R2 (Video/File Storage) ----
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_BUCKET="bakaloriaa-bey-videos"
R2_ACCESS_KEY_ID="your-access-key"
R2_SECRET_ACCESS_KEY="your-secret-key"
R2_PUBLIC_URL="https://pub-xxx.r2.dev"
# S3-compatible endpoint:
R2_ENDPOINT="https://[account-id].r2.cloudflarestorage.com"

# ---- Video Processing ----
FFMPEG_PATH="/usr/bin/ffmpeg"
FFPROBE_PATH="/usr/bin/ffprobe"
VIDEO_ENCRYPTION_KEY="generate-32-byte-hex-key"

# ---- Payment Gateways (future) ----
PAYMOB_API_KEY=""
PAYMOB_INTEGRATION_ID=""
INSTAPAY_API_KEY=""

# ---- Email (SMTP) ----
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
FROM_EMAIL="noreply@bakaloriaa-bey.com"
