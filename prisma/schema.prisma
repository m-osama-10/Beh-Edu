generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  email          String          @unique
  password_hash  String
  name           String
  phone          String?
  role           user_role       @default(STUDENT)
  avatar_url     String?
  email_verified DateTime?       @db.Timestamptz(6)
  status         user_status     @default(ACTIVE)
  created_at     DateTime        @default(now()) @db.Timestamptz(6)
  updated_at     DateTime        @default(now()) @db.Timestamptz(6)
  certificates   Certificate[]
  enrollments    Enrollment[]
  favorites      Favorite[]
  notifications  Notification[]
  payments       Payment[]
  profiles       Profile?
  reviews        Review[]
  students       Student?
  subscriptions  Subscription[]
  teachers       Teacher?
  watch_progress WatchProgress[]

  @@index([email], map: "idx_users_email")
  @@index([role], map: "idx_users_role")
  @@map("users")
}

model Profile {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id    String    @unique @db.Uuid
  bio        String?
  city       String?
  country    String?   @default("مصر")
  facebook   String?
  whatsapp   String?
  birth_date DateTime? @db.Date
  gender     String?
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @default(now()) @db.Timestamptz(6)
  users      User      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("profiles")
}

model Subject {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name      String   @unique
  nameEn    String?  @map("name_en")
  icon      String?
  color     String?
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  courses   Course[]

  @@map("subjects")
}

model Grade {
  id        String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name      String    @unique
  nameEn    String?   @map("name_en")
  level     Int
  sortOrder Int       @default(0) @map("sort_order")
  isActive  Boolean   @default(true) @map("is_active")
  courses   Course[]
  students  Student[]

  @@map("grades")
}

model Teacher {
  id               String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id          String         @unique @db.Uuid
  title            String?
  bio              String?
  specialization   String?
  years_experience Int?
  education        String?
  verified         Boolean        @default(false)
  approved         Boolean        @default(false)
  rating           Float          @default(0) @db.Real
  total_students   Int            @default(0)
  total_courses    Int            @default(0)
  total_revenue    Float          @default(0) @db.Real
  paypal_account   String?
  bank_account     String?
  created_at       DateTime       @default(now()) @db.Timestamptz(6)
  updated_at       DateTime       @default(now()) @db.Timestamptz(6)
  announcements    Announcement[]
  courses          Course[]
  users            User           @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([approved], map: "idx_teachers_approved")
  @@map("teachers")
}

model Student {
  id                String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id           String          @unique @db.Uuid
  grade_id          String?         @db.Uuid
  school_name       String?
  target_year       String?
  total_spent       Float           @default(0) @db.Real
  total_courses     Int             @default(0)
  completed_courses Int             @default(0)
  data_saver_mode   Boolean         @default(true)
  created_at        DateTime        @default(now()) @db.Timestamptz(6)
  updated_at        DateTime        @default(now()) @db.Timestamptz(6)
  certificates      Certificate[]
  enrollments       Enrollment[]
  favorites         Favorite[]
  grades            Grade?          @relation(fields: [grade_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users             User            @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  watch_progress    WatchProgress[]

  @@map("students")
}

model Course {
  id                String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  teacher_id        String         @db.Uuid
  subject_id        String         @db.Uuid
  grade_id          String?        @db.Uuid
  title             String
  slug              String         @unique
  description       String
  cover_image_url   String?
  preview_video_url String?
  price             Float          @default(0) @db.Real
  discount_price    Float?         @db.Real
  discount_until    DateTime?      @db.Timestamptz(6)
  level             course_level   @default(BEGINNER)
  academic_year     String?
  language          String?        @default("العربية")
  is_published      Boolean        @default(false)
  is_featured       Boolean        @default(false)
  views             Int            @default(0)
  rating            Float          @default(0) @db.Real
  rating_count      Int            @default(0)
  student_count     Int            @default(0)
  total_lessons     Int            @default(0)
  total_duration    Int            @default(0)
  created_at        DateTime       @default(now()) @db.Timestamptz(6)
  updated_at        DateTime       @default(now()) @db.Timestamptz(6)
  announcements     Announcement[]
  certificates      Certificate[]
  grades            Grade?         @relation(fields: [grade_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subjects          Subject        @relation(fields: [subject_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  teachers          Teacher        @relation(fields: [teacher_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  enrollments       Enrollment[]
  favorites         Favorite[]
  reviews           Review[]
  sections          Section[]

  @@index([is_featured], map: "idx_courses_featured")
  @@index([grade_id], map: "idx_courses_grade")
  @@index([is_published], map: "idx_courses_published")
  @@index([subject_id], map: "idx_courses_subject")
  @@index([teacher_id], map: "idx_courses_teacher")
  @@map("courses")
}

model Section {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  course_id   String   @db.Uuid
  title       String
  description String?
  sort_order  Int      @default(0)
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  lessons     Lesson[]
  courses     Course   @relation(fields: [course_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([course_id], map: "idx_sections_course")
  @@map("sections")
}

model Lesson {
  id                 String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  section_id         String             @db.Uuid
  title              String
  description        String?
  sort_order         Int                @default(0)
  duration           Int                @default(0)
  is_preview         Boolean            @default(false)
  is_published       Boolean            @default(true)
  created_at         DateTime           @default(now()) @db.Timestamptz(6)
  updated_at         DateTime           @default(now()) @db.Timestamptz(6)
  lesson_attachments LessonAttachment[]
  sections           Section            @relation(fields: [section_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  quizzes            Quiz[]
  videos             Video?
  watch_progress     WatchProgress[]

  @@index([section_id], map: "idx_lessons_section")
  @@map("lessons")
}

model Video {
  id                    String               @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  lesson_id             String               @unique @db.Uuid
  original_url          String?
  r2_key                String?
  hls_playlist_url      String?
  status                video_status         @default(UPLOADED)
  duration_480p         Int?
  duration_720p         Int?
  size_480p             BigInt?
  size_720p             BigInt?
  encryption_key        String?
  thumbnail_url         String?
  created_at            DateTime             @default(now()) @db.Timestamptz(6)
  updated_at            DateTime             @default(now()) @db.Timestamptz(6)
  video_processing_jobs VideoProcessingJob[]
  lessons               Lesson               @relation(fields: [lesson_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("videos")
}

model VideoProcessingJob {
  id           String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  video_id     String     @db.Uuid
  type         job_type
  status       job_status @default(QUEUED)
  progress     Int        @default(0)
  error        String?
  started_at   DateTime?  @db.Timestamptz(6)
  completed_at DateTime?  @db.Timestamptz(6)
  created_at   DateTime   @default(now()) @db.Timestamptz(6)
  videos       Video      @relation(fields: [video_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([status], map: "idx_jobs_status")
  @@map("video_processing_jobs")
}

model LessonAttachment {
  id              String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  lesson_id       String   @db.Uuid
  file_name       String
  file_url        String
  file_type       String
  file_size       BigInt
  is_downloadable Boolean  @default(true)
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  lessons         Lesson   @relation(fields: [lesson_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("lesson_attachments")
}

model Enrollment {
  id                     String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  student_id             String    @db.Uuid
  course_id              String    @db.Uuid
  user_id                String    @db.Uuid
  payment_id             String?   @db.Uuid
  price_paid             Float     @default(0) @db.Real
  progress               Float     @default(0) @db.Real
  completed_lessons      Int       @default(0)
  last_watched_lesson_id String?   @db.Uuid
  enrolled_at            DateTime  @default(now()) @db.Timestamptz(6)
  completed_at           DateTime? @db.Timestamptz(6)
  is_active              Boolean   @default(true)
  courses                Course    @relation(fields: [course_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  students               Student   @relation(fields: [student_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users                  User      @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  payments               Payment[]

  @@unique([student_id, course_id])
  @@index([course_id], map: "idx_enrollments_course")
  @@index([student_id], map: "idx_enrollments_student")
  @@map("enrollments")
}

model Payment {
  id            String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id       String         @db.Uuid
  enrollment_id String?        @db.Uuid
  amount        Float          @db.Real
  currency      String         @default("EGP")
  method        payment_method
  status        payment_status @default(PENDING)
  provider_ref  String?
  teacher_share Float?         @db.Real
  platform_fee  Float?         @db.Real
  created_at    DateTime       @default(now()) @db.Timestamptz(6)
  updated_at    DateTime       @default(now()) @db.Timestamptz(6)
  enrollments   Enrollment?    @relation(fields: [enrollment_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users         User           @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([status], map: "idx_payments_status")
  @@index([user_id], map: "idx_payments_user")
  @@map("payments")
}

model WatchProgress {
  id               String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id          String   @db.Uuid
  student_id       String   @db.Uuid
  lesson_id        String   @db.Uuid
  position         Int      @default(0)
  duration         Int      @default(0)
  watched_seconds  Int      @default(0)
  data_consumed_mb Float    @default(0) @db.Real
  quality          String   @default("480p")
  completed        Boolean  @default(false)
  last_watched_at  DateTime @default(now()) @db.Timestamptz(6)
  created_at       DateTime @default(now()) @db.Timestamptz(6)
  updated_at       DateTime @default(now()) @db.Timestamptz(6)
  lessons          Lesson   @relation(fields: [lesson_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  students         Student  @relation(fields: [student_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users            User     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, lesson_id])
  @@index([user_id], map: "idx_watch_user")
  @@map("watch_progress")
}

model Quiz {
  id            String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  lesson_id     String     @db.Uuid
  title         String
  description   String?
  passing_score Int        @default(60)
  time_limit    Int?
  attempts      Int        @default(0)
  created_at    DateTime   @default(now()) @db.Timestamptz(6)
  questions     Question[]
  lessons       Lesson     @relation(fields: [lesson_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("quizzes")
}

model Question {
  id          String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  quiz_id     String        @db.Uuid
  text        String
  type        question_type @default(SINGLE_CHOICE)
  points      Int           @default(1)
  explanation String?
  sort_order  Int           @default(0)
  answers     Answer[]
  quizzes     Quiz          @relation(fields: [quiz_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("questions")
}

model Answer {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  question_id String   @db.Uuid
  text        String
  is_correct  Boolean  @default(false)
  sort_order  Int      @default(0)
  questions   Question @relation(fields: [question_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("answers")
}

model Review {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id    String   @db.Uuid
  course_id  String   @db.Uuid
  rating     Int
  comment    String?
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
  courses    Course   @relation(fields: [course_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      User     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, course_id])
  @@index([course_id], map: "idx_reviews_course")
  @@map("reviews")
}

model Favorite {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id    String   @db.Uuid
  student_id String   @db.Uuid
  course_id  String   @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz(6)
  courses    Course   @relation(fields: [course_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  students   Student  @relation(fields: [student_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      User     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, course_id])
  @@map("favorites")
}

model Certificate {
  id                 String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id            String   @db.Uuid
  student_id         String   @db.Uuid
  course_id          String   @db.Uuid
  certificate_number String   @unique
  final_score        Float    @db.Real
  issued_at          DateTime @default(now()) @db.Timestamptz(6)
  courses            Course   @relation(fields: [course_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  students           Student  @relation(fields: [student_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users              User     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "idx_certificates_user")
  @@map("certificates")
}

model Notification {
  id         String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id    String            @db.Uuid
  title      String
  message    String
  type       notification_type
  is_read    Boolean           @default(false)
  link       String?
  created_at DateTime          @default(now()) @db.Timestamptz(6)
  users      User              @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id, is_read], map: "idx_notifications_unread")
  @@index([user_id], map: "idx_notifications_user")
  @@map("notifications")
}

model Announcement {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  teacher_id String?  @db.Uuid
  course_id  String?  @db.Uuid
  title      String
  content    String
  is_pinned  Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  courses    Course?  @relation(fields: [course_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  teachers   Teacher? @relation(fields: [teacher_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("announcements")
}

model Subscription {
  id         String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id    String            @db.Uuid
  plan       subscription_plan
  status     String            @default("ACTIVE")
  start_date DateTime          @default(now()) @db.Timestamptz(6)
  end_date   DateTime          @db.Timestamptz(6)
  amount     Float             @db.Real
  auto_renew Boolean           @default(false)
  created_at DateTime          @default(now()) @db.Timestamptz(6)
  users      User              @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("subscriptions")
}

enum course_level {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  ALL_LEVELS
}

enum job_status {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum job_type {
  TRANSCODE_480P
  TRANSCODE_720P
  HLS_PACKAGE
  ENCRYPT
  THUMBNAIL
}

enum notification_type {
  INFO
  SUCCESS
  WARNING
  ERROR
  ANNOUNCEMENT
  LESSON
  PAYMENT
  CERTIFICATE
}

enum payment_method {
  VODAFONE_CASH
  ETISALAT_CASH
  ORANGE_CASH
  FAWRY
  CARD
  INSTAPAY
}

enum payment_status {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum question_type {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  TRUE_FALSE
  TEXT
}

enum subscription_plan {
  MONTHLY
  QUARTERLY
  SEMESTER
  YEARLY
}

enum user_role {
  ADMIN
  TEACHER
  STUDENT
}

enum user_status {
  ACTIVE
  PENDING
  SUSPENDED
  BANNED
}

enum video_status {
  UPLOADED
  PROCESSING
  READY
  FAILED
}


